# Deployer wallet (pays gas for contract deployment)
DEPLOYER_PRIVATE_KEY=

# Relayer wallet address (passed to contract constructor; relay backend signs txs)
RELAYER_ADDRESS=

# Relayer private key (relay backend uses this to submit mintStamp txs)
RELAYER_PRIVATE_KEY=

# Deployed MonadStamp contract address (optional if deployments/monadTestnet.json exists)
CONTRACT_ADDRESS=

# Relay server port (optional — defaults to 3001)
PORT=3001

# Monad Testnet RPC (optional — defaults to https://testnet-rpc.monad.xyz)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
